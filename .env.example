PORT=4339
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Prisma: use DATABASE_URL ou POSTGRES_URI (mesmo nome do Backend OnlyFlow)
# Produção onlydb:
# POSTGRES_URI=postgres://onlydbflow:PASS@easy.onlyflow.com.br:5435/onlydb?sslmode=disable
# Sandbox local:
# DATABASE_URL=postgresql://USER:PASS@HOST:5433/sandbox?sslmode=disable
POSTGRES_URI=
DATABASE_URL=

# Mesmo JWT_SECRET do Backend OnlyFlow
JWT_SECRET=

# Mesma ONLYFLOW_INTERNAL_KEY do Backend (lembretes de atividade por e-mail)
ONLYFLOW_INTERNAL_KEY=
