PORT=4339
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Obrigatório para Prisma (não use POSTGRES_URI)
# Com Docker local: postgresql://crmflow:crmflow@localhost:5434/crmflow
# Com Postgres OnlyFlow (sandbox): mesma URL do Backend + schema isolado crm_flow no migrate
DATABASE_URL=postgresql://USER:PASS@HOST:5433/sandbox?sslmode=disable

# Mesmo JWT_SECRET do Backend OnlyFlow
JWT_SECRET=

# Mesma ONLYFLOW_INTERNAL_KEY do Backend (lembretes de atividade por e-mail)
ONLYFLOW_INTERNAL_KEY=
