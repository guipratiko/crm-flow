generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["crm_flow"]
}

enum DealStatus {
  open
  won
  lost

  @@schema("crm_flow")
}

enum ActivityStatus {
  pending
  completed
  cancelled

  @@schema("crm_flow")
}

enum TimelineEntityType {
  contact
  company
  deal

  @@schema("crm_flow")
}

enum ProductStatus {
  active
  inactive

  @@schema("crm_flow")
}

model TenantProfile {
  id        String   @id
  name      String
  document  String?
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@schema("crm_flow")
  @@map("tenant_profiles")
}

model Contact {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  name              String
  email             String?
  phone             String?
  whatsapp          String?
  position          String?
  companyId         String?  @map("company_id")
  responsibleUserId String?  @map("responsible_user_id")
  tags              String[] @default([])
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  company      ClientCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  source       String           @default("manual")
  dealLinks    DealContact[]
  activities   Activity[]
  mainDeals    Deal[]           @relation("DealMainContact")
  chatLinks    ChatContactLink[]

  @@index([tenantId])
  @@index([tenantId, companyId])
  @@schema("crm_flow")
  @@map("contacts")
}

model ClientCompany {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  name              String
  tradeName         String?  @map("trade_name")
  document          String?
  segment           String?
  website           String?
  phone             String?
  email             String?
  address           String?
  partners          String[] @default([]) @map("partners")
  logoUrl           String?  @map("logo_url")
  responsibleUserId String?  @map("responsible_user_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  contacts   Contact[]
  deals      Deal[]
  activities Activity[]

  @@index([tenantId])
  @@schema("crm_flow")
  @@map("client_companies")
}

model Pipeline {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  stages PipelineStage[]
  deals  Deal[]

  @@index([tenantId])
  @@schema("crm_flow")
  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  pipelineId  String   @map("pipeline_id")
  name        String
  order       Int
  shortId     Int      @map("short_id")
  color       String   @default("#3B82F6")
  probability Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([tenantId, pipelineId, shortId])
  @@index([tenantId, pipelineId])
  @@schema("crm_flow")
  @@map("pipeline_stages")
}

model Deal {
  id                String     @id @default(uuid())
  tenantId          String     @map("tenant_id")
  title             String
  description       String?
  value             Decimal    @default(0) @db.Decimal(14, 2)
  status            DealStatus @default(open)
  probability       Int        @default(0)
  expectedCloseDate DateTime?  @map("expected_close_date")
  pipelineId        String     @map("pipeline_id")
  stageId           String     @map("stage_id")
  companyId         String?    @map("company_id")
  mainContactId     String?    @map("main_contact_id")
  responsibleUserId String?    @map("responsible_user_id")
  lossReason        String?    @map("loss_reason")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  pipeline    Pipeline        @relation(fields: [pipelineId], references: [id])
  stage       PipelineStage   @relation(fields: [stageId], references: [id])
  company     ClientCompany?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  mainContact Contact?        @relation("DealMainContact", fields: [mainContactId], references: [id], onDelete: SetNull)
  contacts    DealContact[]
  products    DealProduct[]
  activities  Activity[]
  timelineMessages DealTimelineMessage[]

  @@index([tenantId])
  @@index([tenantId, stageId])
  @@index([tenantId, status])
  @@schema("crm_flow")
  @@map("deals")
}

model DealTimelineMessage {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  dealId        String   @map("deal_id")
  chatContactId String   @map("chat_contact_id")
  messageId     String   @map("message_id")
  createdAt     DateTime @default(now()) @map("created_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, messageId])
  @@index([tenantId, dealId])
  @@schema("crm_flow")
  @@map("deal_timeline_messages")
}

model DealContact {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  contactId String   @map("contact_id")
  dealId    String   @map("deal_id")
  role      String?
  createdAt DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, contactId])
  @@index([tenantId])
  @@schema("crm_flow")
  @@map("deal_contacts")
}

model Product {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  name        String
  description String?
  category    String?
  sku         String?
  price       Decimal       @default(0) @db.Decimal(14, 2)
  costPrice   Decimal?      @map("cost_price") @db.Decimal(14, 2)
  stock       Int           @default(0)
  size        String?
  weight      Decimal?      @db.Decimal(10, 3)
  weightUnit  String?       @map("weight_unit")
  status      ProductStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  dealProducts DealProduct[]

  @@index([tenantId])
  @@schema("crm_flow")
  @@map("products")
}

model DealProduct {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  dealId    String   @map("deal_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  unitPrice Decimal  @default(0) @map("unit_price") @db.Decimal(14, 2)
  discount  Decimal  @default(0) @db.Decimal(14, 2)
  total     Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now()) @map("created_at")

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([tenantId, dealId])
  @@schema("crm_flow")
  @@map("deal_products")
}

model Activity {
  id                String         @id @default(uuid())
  tenantId          String         @map("tenant_id")
  type              String         @db.VarChar(64)
  title             String
  description       String?
  dueDate           DateTime?      @map("due_date")
  status            ActivityStatus @default(pending)
  contactId         String?        @map("contact_id")
  companyId         String?        @map("company_id")
  dealId            String?        @map("deal_id")
  responsibleUserId            String?   @map("responsible_user_id")
  reminderSentAt               DateTime? @map("reminder_sent_at")
  overdueReminderSentAt        DateTime? @map("overdue_reminder_sent_at")
  reminderWhatsappSentAt       DateTime? @map("reminder_whatsapp_sent_at")
  overdueReminderWhatsappSentAt DateTime? @map("overdue_reminder_whatsapp_sent_at")
  reminderPushSentAt           DateTime? @map("reminder_push_sent_at")
  overdueReminderPushSentAt    DateTime? @map("overdue_reminder_push_sent_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  contact Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company ClientCompany?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deal    Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@schema("crm_flow")
  @@map("activities")
}

model ActivityDigestLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  digestDay DateTime @map("digest_day") @db.Date
  sentAt    DateTime @default(now()) @map("sent_at")

  @@unique([tenantId, userId, digestDay])
  @@index([digestDay])
  @@schema("crm_flow")
  @@map("activity_digest_logs")
}

model ActivityDigestWhatsappLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  digestDay DateTime @map("digest_day") @db.Date
  sentAt    DateTime @default(now()) @map("sent_at")

  @@unique([tenantId, userId, digestDay])
  @@index([digestDay])
  @@schema("crm_flow")
  @@map("activity_digest_whatsapp_logs")
}

model ActivityDigestPushLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  digestDay DateTime @map("digest_day") @db.Date
  sentAt    DateTime @default(now()) @map("sent_at")

  @@unique([tenantId, userId, digestDay])
  @@index([digestDay])
  @@schema("crm_flow")
  @@map("activity_digest_push_logs")
}

model ActivityTypeDef {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  slug      String   @db.VarChar(64)
  sortOrder Int      @default(0) @map("sort_order")
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@schema("crm_flow")
  @@map("activity_type_defs")
}

model AgendaView {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  sortOrder    Int      @default(0) @map("sort_order")
  filterConfig Json     @map("filter_config")
  isSystem     Boolean  @default(false) @map("is_system")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@schema("crm_flow")
  @@map("agenda_views")
}

model ChatContactLink {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  crmContactId   String   @map("crm_contact_id")
  chatContactId  String   @map("chat_contact_id")
  chatInstanceId String   @map("chat_instance_id")
  chatChannel    String   @map("chat_channel") @db.VarChar(20)
  linkedByUserId String?  @map("linked_by_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [crmContactId], references: [id], onDelete: Cascade)

  @@unique([tenantId, chatContactId])
  @@index([tenantId, crmContactId])
  @@schema("crm_flow")
  @@map("chat_contact_links")
}

model TimelineEvent {
  id          String             @id @default(uuid())
  tenantId    String             @map("tenant_id")
  entityType  TimelineEntityType @map("entity_type")
  entityId    String             @map("entity_id")
  action      String
  description String
  metadata    Json?
  userId      String?            @map("user_id")
  createdAt   DateTime           @default(now()) @map("created_at")

  @@index([tenantId, entityType, entityId])
  @@schema("crm_flow")
  @@map("timeline_events")
}
